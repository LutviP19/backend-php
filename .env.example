PHP_VERSION=8.3.0
APP_NAME="Backend PHP"
APP_VERSION=1.0.0
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_PORT=8000
APP_DOMAIN=localhost
APP_URL=http://${APP_DOMAIN}:${APP_PORT}

SVC_IP=127.0.0.1
SVC_PORT=9502
SVC_URL=http://${SVC_IP}:${SVC_PORT}


ENCRYPTION_KEY=
HASH_KEY=


HEADER_TOKEN=


GEMINI_API_KEY=xxxxx
# GEMINI_MODEL=gemini-3-flash-preview
GEMINI_MODEL=gemini-2.5-flash-preview-09-2025
INSPECTOR_INGESTION_KEY=xxx

OLLAMA_MODEL=gemma3
EMBEDDING_MODEL=embeddinggemma

# DB_CONNECTION=sqlite
# DB_DATABASE=backend_php.sqlite

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=backend_php
DB_USERNAME=root
DB_PASSWORD=

# SESSION_DRIVER=file
SESSION_DRIVER=redis
SESSION_REGENERATE=300
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
CACHE_PREFIX=

MB_CONNECTION=rabbitmq
MB_HOST=127.0.0.1
MB_PORT=5672
MB_USERNAME=guest
MB_PASSWORD=guest
MB_QUEUE_NAME=backend_php-queue

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=mailpit
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
